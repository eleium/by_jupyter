    "temp = input(\"不妨猜一下小甲鱼现在心里想的是哪个数字：\")\n",
    "guess = int(temp)\n",
    "\n",
    "if guess == 8:\n",
    "    print(\"猜猜对啦！\")\n",
    "    print(\"但是没有奖励哦。\")\n",
    "else:\n",
    "    print(\"没有蒙对哦。\")\n",
    "    print(\"结束啦，没啥意思。\\n\")\n",
    "    # 这一行的缩进在else下，猜错运行。\n",
    "print('游戏结束，game over,再来一局')#这一行的缩进在if下，猜对猜错都会运行。"
   ]
